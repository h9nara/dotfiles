# Ghostty Configuration
# https://ghostty.org/docs/config

theme = 3024 day

# 将 option + shift + Enter 绑定为切换 Quick Terminal
# global: 前缀意味着即使 Ghostty 没有焦点，你也可以呼出它
keybind = global:option+shift+enter=toggle_quick_terminal

# --- Keybindings ---
# copied from https://gist.github.com/davila7/5b07f55a6e65a06c121da9702d10c2e2
  # Tabs
  keybind = cmd+t=new_tab
  keybind = cmd+shift+left=previous_tab
  keybind = cmd+shift+right=next_tab
  keybind = cmd+w=close_surface

  # Splits
  keybind = cmd+r=new_split:right
  keybind = cmd+d=new_split:down
  keybind = cmd+ctrl+h=goto_split:left
  keybind = cmd+ctrl+l=goto_split:right
  keybind = cmd+ctrl+k=goto_split:top
  keybind = cmd+ctrl+j=goto_split:bottom

  # Font size
  keybind = cmd+plus=increase_font_size:1
  keybind = cmd+minus=decrease_font_size:1
  keybind = cmd+zero=reset_font_size

  # Splits management
  keybind = cmd+shift+e=equalize_splits
  keybind = cmd+shift+f=toggle_split_zoom
